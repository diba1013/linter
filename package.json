{
	"name": "@diba1013/linter",
	"version": "0.0.0-development",
	"description": "The missing linter configurations for personal use.",
	"license": "MIT",
	"repository": {
		"url": "git+https://github.com/diba1013/linter.git"
	},
	"author": "diba1013",
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": ">=24"
	},
	"type": "module",
	"files": [
		"src"
	],
	"exports": {
		".": "./src/index.js",
		"./eslint": "./src/recommended.eslint.js",
		"./prettier": "./src/recommended.prettier.js"
	},
	"main": "./src/index.js",
	"scripts": {
		"prepare": "husky",
		"lint": "eslint .",
		"lint:fix": "eslint --fix ."
	},
	"peerDependencies": {
		"eslint": "9.x",
		"prettier": "3.x"
	},
	"dependencies": {
		"@eslint/eslintrc": "3.3.5",
		"@eslint/js": "10.0.1",
		"@eslint/json": "1.1.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-jsonc": "3.1.2",
		"eslint-plugin-perfectionist": "5.6.0",
		"eslint-plugin-prettier": "5.5.5",
		"eslint-plugin-unicorn": "63.0.0",
		"eslint-plugin-vue": "10.8.0",
		"eslint-plugin-yml": "3.3.1",
		"globals": "17.4.0",
		"typescript-eslint": "8.57.0",
		"vue-eslint-parser": "10.4.0"
	},
	"devDependencies": {
		"@commitlint/cli": "20.4.4",
		"@commitlint/config-conventional": "20.4.4",
		"@diba1013/linter": "workspace:*",
		"@types/node": "25.5.0",
		"baseline-browser-mapping": "2.10.7",
		"eslint": "10.0.3",
		"husky": "9.1.7",
		"lint-staged": "16.3.3",
		"prettier": "3.8.1",
		"semantic-release": "25.0.3",
		"typescript": "5.9.3"
	}
