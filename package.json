{
	"name": "@diba1013/linter",
	"version": "0.0.0-development",
	"description": "The missing linter configurations for personal use.",
	"license": "MIT",
	"repository": {
		"url": "git+https://github.com/diba1013/linter.git"
	},
	"author": "diba1013",
	"packageManager": "pnpm@11.15.1",
	"engines": {
		"node": ">=24"
	},
	"type": "module",
	"files": [
		"src"
	],
	"exports": {
		".": "./src/index.js",
		"./eslint": "./src/recommended.eslint.js",
		"./prettier": "./src/recommended.prettier.js"
	},
	"main": "./src/index.js",
	"scripts": {
		"prepare": "husky",
		"lint": "eslint .",
		"lint:fix": "eslint --fix ."
	},
	"peerDependencies": {
		"eslint": "9.x",
		"prettier": "3.x"
	},
	"dependencies": {
		"@eslint/eslintrc": "3.3.6",
		"@eslint/js": "10.0.1",
		"@eslint/json": "2.0.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-jsonc": "3.3.0",
		"eslint-plugin-perfectionist": "5.10.0",
		"eslint-plugin-prettier": "5.5.6",
		"eslint-plugin-unicorn": "72.0.0",
		"eslint-plugin-vue": "10.10.0",
		"eslint-plugin-yml": "3.6.0",
		"globals": "17.7.0",
		"typescript-eslint": "8.65.0",
		"vue-eslint-parser": "10.4.1"
	},
	"devDependencies": {
		"@commitlint/cli": "21.2.1",
		"@commitlint/config-conventional": "21.2.0",
		"@diba1013/linter": "workspace:*",
		"@types/node": "26.1.1",
		"baseline-browser-mapping": "2.10.43",
		"eslint": "10.7.0",
		"husky": "9.1.7",
		"lint-staged": "17.1.0",
		"prettier": "3.9.5",
		"semantic-release": "25.0.8",
		"typescript": "6.0.3"
	}
